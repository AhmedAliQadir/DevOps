{
  "name": "devops-portfolio-api",
  "version": "1.0.0",
  "description": "A Node.js REST API showcasing DevOps skills for recruiters",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --coverage",
    "lint": "eslint src/",
    "docker:build": "docker build -t devops-portfolio-api .",
    "docker:run": "docker run -p 3000:3000 devops-portfolio-api",
    "docker:stop": "docker stop $(docker ps -q --filter ancestor=devops-portfolio-api)"
  },
  "keywords": [
    "devops",
    "docker",
    "ci-cd",
    "nodejs",
    "portfolio"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.56.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
