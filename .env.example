# Environment Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
LOG_FORMAT=json

# CORS
CORS_ORIGIN=*

# Database (optional)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=devopsportfolio
DB_USERNAME=admin
DB_PASSWORD=your_secure_password

# AWS (for Terraform)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
